# Grafana Mimir Distributed Configuration for production
# Microservices architecture (no Kafka ingest-storage) with Pod Identity for S3 access.
#
# NOTE on chart v6.0.6 defaults:
# - chart のデフォルトは `ingest_storage` 有効 (= Kafka 経由) の新 architecture。
#   本 sub-project は Prometheus → distributor → ingester の従来 microservices
#   path を使うため、structuredConfig で ingest_storage を disable し、kafka/minio
#   subchart も disable する。
# - chart の API gateway は `gateway:` key (nginx-based)。`nginx:` という
#   top-level key は存在しない (chart README の "8 components: nginx" は
#   gateway component の通称表記)。

# =============================================================================
# ServiceAccount (Pod Identity, no IRSA annotation needed)
# =============================================================================
# Pod Identity Association (aws/eks-metrics/ stack で provision 済) が
# monitoring:mimir SA を IAM role に紐付けるため、Helm chart 側で
# eks.amazonaws.com/role-arn annotation を入れる必要なし。
serviceAccount:
  create: true
  name: mimir

# =============================================================================
# Mimir runtime config (S3 backend を structuredConfig で override)
# =============================================================================
mimir:
  structuredConfig:
    common:
      storage:
        backend: s3
        s3:
          bucket_name: {{ .Values.mimir.bucketName }}
          endpoint: s3.ap-northeast-1.amazonaws.com
          region: ap-northeast-1
          # SSE-S3 (AES256) は bucket-level の default encryption で適用済
    blocks_storage:
      # NOTE: Mimir 3.x の TSDB validator は `^[A-Za-z0-9]+$` のみ許可
      # (slash/underscore/hyphen 不可)。slash 区切りは Mimir 内部で
      # `<prefix>/<tenant>/<block_id>` の形に自動付加される。
      storage_prefix: "{{ .Values.mimir.bucketPathPrefix }}"
      backend: s3
      s3:
        bucket_name: {{ .Values.mimir.bucketName }}
        endpoint: s3.ap-northeast-1.amazonaws.com
        region: ap-northeast-1
    # multi-tenant 不要 (panicboat 1 tenant)
    multitenancy_enabled: false
    # 従来 microservices path (distributor → ingester gRPC push) に戻す
    ingest_storage:
      enabled: false
    ingester:
      push_grpc_method_enabled: true
      ring:
        # 1 ingester replica 構成のため RF=1。chart default RF=3 だと distributor が
        # quorum (= RF/2+1=2) を満たせず "at least 2 live replicas required" で
        # write reject、querier も ring unhealthy で query 不可になる。
        replication_factor: 1
    store_gateway:
      sharding_ring:
        # 1 store_gateway replica 構成のため RF=1。ingester ring と同じ理由で
        # chart default RF=3 だと query path で ring unhealthy になる。
        replication_factor: 1
    limits:
      # chart default `max_global_series_per_user: 150000` は small cluster で
      # apiserver high-cardinality histogram bucket (= apiserver_request_*) で
      # 容易に hit する。500K に拡大して buffer 確保、prometheus-operator の
      # writeRelabelConfigs で長期 cardinality 制御 (= apiserver bucket drop)
      # と組合せて運用する。
      max_global_series_per_user: 500000
    # NOTE: frontend / frontend_worker は chart default に任せる
    # (query_scheduler 有効時は chart が scheduler_address を query-scheduler
    # service に向けて自動設定。Mimir 3.x の worker.Config struct は
    # frontend_address を持たないため override 不可)。

# =============================================================================
# Disable bundled subcharts (本 sub-project では使わない)
# =============================================================================
# AWS S3 を使うため、開発用 minio subchart を disable
minio:
  enabled: false
# 従来 microservices path を使うため、Kafka subchart を disable
kafka:
  enabled: false

# =============================================================================
# Disable unused Mimir components (本 sub-project で不要な 4 component)
# =============================================================================
# kube-prometheus-stack 内蔵 Alertmanager を使うため、Mimir 内蔵を disable
alertmanager:
  enabled: false
# kube-prometheus-stack 内蔵 Prometheus rule で評価するため、Mimir 内蔵 ruler を disable
ruler:
  enabled: false
# NOTE: query_scheduler は Mimir 3.x で querier ↔ query-frontend 接続の前提
# コンポーネント (chart default の true を採用、disable すると
# Mimir 3.x には存在しない frontend_worker.frontend_address を config schema が
# 要求し error になる)。
# overrides_exporter: multi-tenant 不要 (1 tenant)
overrides_exporter:
  enabled: false
# NOTE: smoke_test Job は helm.sh/hook: test 付きで helm test 時のみ実行される
# (= chart 通常 deploy では runtime workload にならない)。chart に enabled key
# がないため明示的に disable する手段なし。

# =============================================================================
# Enabled components (本 sub-project で必要な 8 component) のリソース設定
# =============================================================================

# gateway: chart の HTTP API entry point (nginx-based reverse proxy)
gateway:
  enabled: true
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 200m
      memory: 256Mi

distributor:
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      cpu: 500m
      memory: 1Gi

ingester:
  replicas: 1
  # chart v6.x default は zoneAwareReplication 有効 (= 3 zone × 1 pod/zone = 3 pod 構成)。
  # small cluster で 1 pod のみ動かすため disable。
  zoneAwareReplication:
    enabled: false
  resources:
    requests:
      cpu: 200m
      memory: 512Mi
    limits:
      cpu: 1
      memory: 2Gi
  persistentVolume:
    enabled: true
    storageClass: gp3
    size: 10Gi

querier:
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      cpu: 500m
      memory: 1Gi

query_frontend:
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      cpu: 500m
      memory: 512Mi

store_gateway:
  replicas: 1
  # chart v6.x default は zoneAwareReplication 有効 (= 3 zone × 1 pod/zone = 3 pod 構成)。
  # small cluster で 1 pod のみ動かすため disable。
  zoneAwareReplication:
    enabled: false
  resources:
    requests:
      cpu: 100m
      memory: 512Mi
    limits:
      cpu: 500m
      memory: 2Gi
  persistentVolume:
    enabled: true
    storageClass: gp3
    size: 20Gi

compactor:
  replicas: 1
  resources:
    requests:
      cpu: 100m
      memory: 512Mi
    limits:
      cpu: 500m
      memory: 2Gi
  persistentVolume:
    enabled: true
    storageClass: gp3
    size: 10Gi

# memcached (chunks-cache) — querier の S3 query 高速化
chunks-cache:
  enabled: true
  replicas: 1
  allocatedMemory: 512
  resources:
    requests:
      cpu: 100m
      memory: 512Mi
    limits:
      cpu: 200m
      memory: 1Gi
